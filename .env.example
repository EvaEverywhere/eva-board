# ---------------------------------------------------------------------------
# Eva Board — root example environment
#
# Used by `docker compose` and `make dev` to source the backend env file.
# Copy to `.env` (root) AND `backend/.env` for a working local stack.
# Mirrors backend/.env.example; see that file for full per-var docs.
# ---------------------------------------------------------------------------

# --- Backend core (REQUIRED) -----------------------------------------------
PORT=8080
DATABASE_URL=postgres://postgres:postgres@localhost:5433/eva_board?sslmode=disable
JWT_SECRET=dev-secret-change-me-please-use-a-long-random-value
APP_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:8082,http://localhost:19006

# --- Auth & email (OPTIONAL in dev; magic links log to stdout if unset) ----
RESEND_API_KEY=
AUTH_EMAIL_FROM="Eva Board <onboarding@example.com>"
MOBILE_APP_SCHEME=eva-board

# --- LLM provider (OPTIONAL; required for board agent verification) --------
LLM_API_KEY=
LLM_MODEL=openai/gpt-4o-mini
LLM_BASE_URL=https://openrouter.ai/api/v1

# --- GitHub integration (OPTIONAL) -----------------------------------------
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_WEBHOOK_SECRET=

# --- Token vault (REQUIRED to store GitHub PATs) ---------------------------
# AES-GCM key (32 bytes, base64). Generate with:
#   openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# --- Codegen agent (OPTIONAL; required for actual agent runs) --------------
# NOTE: the API container does not ship `claude`. Run the API on the host
# (`make dev`) or build a custom image to use the Claude Code agent.
CODEGEN_AGENT=claude-code
CODEGEN_MODEL=
CODEGEN_TIMEOUT=30m
CODEGEN_MAX_OUTPUT_BYTES=10485760
CODEGEN_COMMAND=
CODEGEN_ARGS=

# --- Mobile (Expo) ---------------------------------------------------------
EXPO_PUBLIC_API_URL=http://localhost:8080
