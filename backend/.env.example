PORT=8080
DATABASE_URL=postgres://postgres:postgres@localhost:5433/eva_board?sslmode=disable
JWT_SECRET=dev-secret-change-me-please-use-a-long-random-value
APP_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:8082,http://localhost:19006

# Optional email provider (if unset, magic links are logged to stdout in dev).
RESEND_API_KEY=
AUTH_EMAIL_FROM="Eva Board <onboarding@example.com>"

# Used for deep-link redirect on successful link verification pages.
MOBILE_APP_SCHEME=eva-board

# LLM provider (OpenRouter by default). LLM_API_KEY is required to enable
# any LLM-backed features (e.g. board agent verification scoring).
LLM_API_KEY=
LLM_MODEL=openai/gpt-4o-mini
LLM_BASE_URL=https://openrouter.ai/api/v1

# GitHub API client. Per-user tokens are stored in board_settings; these
# settings configure the API base URL and the secret used to verify
# incoming webhook signatures.
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_WEBHOOK_SECRET=
