# ---------------------------------------------------------------------------
# Eva Board backend — example environment
#
# Copy to backend/.env and fill in the REQUIRED values for the features you
# intend to use. All values below ship with sane local-dev defaults; only
# secrets and provider keys need real values.
# ---------------------------------------------------------------------------

# --- Core (REQUIRED in any non-trivial deployment) -------------------------
PORT=8080
DATABASE_URL=postgres://postgres:postgres@localhost:5433/eva_board?sslmode=disable
# REQUIRED in production. Change before deploying.
JWT_SECRET=dev-secret-change-me-please-use-a-long-random-value
APP_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:8082,http://localhost:19006

# --- Auth & email (OPTIONAL in dev) ----------------------------------------
# If RESEND_API_KEY is empty, magic links are logged to stdout instead of
# being emailed. Required for real email delivery.
RESEND_API_KEY=
AUTH_EMAIL_FROM="Eva Board <onboarding@example.com>"
# Deep-link scheme used to bounce verified magic links into the mobile app.
MOBILE_APP_SCHEME=eva-board

# --- LLM provider (OPTIONAL; required for board agent verification) --------
# OpenRouter by default. LLM_API_KEY is REQUIRED to enable LLM-backed
# features (e.g. board agent verification scoring).
LLM_API_KEY=
LLM_MODEL=openai/gpt-4o-mini
LLM_BASE_URL=https://openrouter.ai/api/v1

# --- GitHub integration (OPTIONAL) -----------------------------------------
# Per-user PATs are stored in board_settings; these settings configure the
# API base URL and the secret used to verify incoming webhook signatures.
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_WEBHOOK_SECRET=

# --- Token vault (REQUIRED to store GitHub PATs) ---------------------------
# AES-GCM key (32 bytes, base64) used to encrypt per-user GitHub PATs at
# rest. Generate with:
#   openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# --- Codegen agent (OPTIONAL; required for actual agent runs) --------------
# Pluggable coding-agent CLI wrapper. See backend/internal/codegen.
# CODEGEN_AGENT: "claude-code" (default) or "generic".
# NOTE: the bundled API container does not ship the `claude` CLI. To run
# real agent tasks, either run the API on the host or build a custom image
# that includes Claude Code (or your agent of choice).
CODEGEN_AGENT=claude-code
# Optional model override forwarded to the agent (e.g. claude --model).
CODEGEN_MODEL=
# Per-invocation wall-clock cap. Go duration string (e.g. 30m, 2h).
CODEGEN_TIMEOUT=30m
# Max bytes of combined stdout+stderr captured per Run (10 MiB default).
CODEGEN_MAX_OUTPUT_BYTES=10485760
# For CODEGEN_AGENT=generic: the binary to invoke (e.g. codex, aider).
CODEGEN_COMMAND=
# Comma-separated extra args prepended to the generic agent's argv.
CODEGEN_ARGS=
